<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="hikbot">

    <!-- =============================================================
         BASE LINK (chassis)
         Box: 0.50 (X) x 0.35 (Y) x 0.18 (Z), mass 5 kg.
         Mounted at z=0.10 in world; wheel radius 0.075 keeps wheels on ground.
         ============================================================= -->
    <link name="base_link">
      <inertial>
        <mass>5.0</mass>
        <pose>0 0 0 0 0 0</pose>
        <inertia>
          <ixx>0.0645</ixx><iyy>0.1177</iyy><izz>0.1552</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="chassis_visual">
        <geometry><box><size>0.50 0.35 0.18</size></box></geometry>
        <material>
          <ambient>0.15 0.25 0.55 1</ambient>
          <diffuse>0.20 0.30 0.70 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>
      <collision name="chassis_collision">
        <geometry><box><size>0.50 0.35 0.18</size></box></geometry>
      </collision>

      <!-- Pi5 + Hailo HAT placeholder (visual only) -->
      <visual name="pi_box">
        <pose>-0.05 0 0.105 0 0 0</pose>
        <geometry><box><size>0.10 0.07 0.03</size></box></geometry>
        <material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material>
      </visual>

      <!-- ===================== IMU (BNO055) ===================== -->
      <sensor name="imu" type="imu">
        <pose>0 0 0.05 0 0 0</pose>
        <update_rate>100</update_rate>
        <always_on>true</always_on>
        <topic>imu</topic>
        <gz_frame_id>imu_link</gz_frame_id>
      </sensor>

      <!-- ===================== Stereo cameras ===================== -->
      <!-- Cam0 = left, Cam1 = right; 54 deg HFOV (V1.3 spec) -->
      <sensor name="cam0" type="camera">
        <pose>0.25 0.03 0.10 0 0 0</pose>
        <update_rate>30</update_rate>
        <always_on>true</always_on>
        <topic>cam0</topic>
        <gz_frame_id>cam0_link</gz_frame_id>
        <camera>
          <horizontal_fov>0.9425</horizontal_fov>
          <image><width>640</width><height>480</height><format>R8G8B8</format></image>
          <clip><near>0.05</near><far>50</far></clip>
        </camera>
      </sensor>
      <sensor name="cam1" type="camera">
        <pose>0.25 -0.03 0.10 0 0 0</pose>
        <update_rate>30</update_rate>
        <always_on>true</always_on>
        <topic>cam1</topic>
        <gz_frame_id>cam1_link</gz_frame_id>
        <camera>
          <horizontal_fov>0.9425</horizontal_fov>
          <image><width>640</width><height>480</height><format>R8G8B8</format></image>
          <clip><near>0.05</near><far>50</far></clip>
        </camera>
      </sensor>

      <!-- ===================== 4 ToF lasers ===================== -->
      <!-- Single-ray gpu_lidar, 0.05–8 m, 20 Hz. Front/Back/Left/Right. -->
      <sensor name="laser_front" type="gpu_lidar">
        <pose>0.27 0 0.04 0 0 0</pose>
        <update_rate>20</update_rate>
        <always_on>true</always_on>
        <topic>scan/front</topic>
        <gz_frame_id>laser_front_link</gz_frame_id>
        <lidar>
          <scan>
            <horizontal><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></horizontal>
            <vertical><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></vertical>
          </scan>
          <range><min>0.05</min><max>8.0</max><resolution>0.01</resolution></range>
        </lidar>
      </sensor>
      <sensor name="laser_back" type="gpu_lidar">
        <pose>-0.27 0 0.04 0 0 3.14159265</pose>
        <update_rate>20</update_rate>
        <always_on>true</always_on>
        <topic>scan/back</topic>
        <gz_frame_id>laser_back_link</gz_frame_id>
        <lidar>
          <scan>
            <horizontal><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></horizontal>
            <vertical><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></vertical>
          </scan>
          <range><min>0.05</min><max>8.0</max><resolution>0.01</resolution></range>
        </lidar>
      </sensor>
      <sensor name="laser_left" type="gpu_lidar">
        <pose>0 0.18 0.04 0 0 1.5707963</pose>
        <update_rate>20</update_rate>
        <always_on>true</always_on>
        <topic>scan/left</topic>
        <gz_frame_id>laser_left_link</gz_frame_id>
        <lidar>
          <scan>
            <horizontal><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></horizontal>
            <vertical><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></vertical>
          </scan>
          <range><min>0.05</min><max>8.0</max><resolution>0.01</resolution></range>
        </lidar>
      </sensor>
      <sensor name="laser_right" type="gpu_lidar">
        <pose>0 -0.18 0.04 0 0 -1.5707963</pose>
        <update_rate>20</update_rate>
        <always_on>true</always_on>
        <topic>scan/right</topic>
        <gz_frame_id>laser_right_link</gz_frame_id>
        <lidar>
          <scan>
            <horizontal><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></horizontal>
            <vertical><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></vertical>
          </scan>
          <range><min>0.05</min><max>8.0</max><resolution>0.01</resolution></range>
        </lidar>
      </sensor>

      <!-- Tiny visual cubes for the lasers so you can see them in Gazebo -->
      <visual name="laser_front_visual">
        <pose>0.27 0 0.04 0 0 0</pose>
        <geometry><box><size>0.03 0.03 0.03</size></box></geometry>
        <material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material>
      </visual>
      <visual name="laser_back_visual">
        <pose>-0.27 0 0.04 0 0 0</pose>
        <geometry><box><size>0.03 0.03 0.03</size></box></geometry>
        <material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material>
      </visual>
      <visual name="laser_left_visual">
        <pose>0 0.18 0.04 0 0 0</pose>
        <geometry><box><size>0.03 0.03 0.03</size></box></geometry>
        <material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material>
      </visual>
      <visual name="laser_right_visual">
        <pose>0 -0.18 0.04 0 0 0</pose>
        <geometry><box><size>0.03 0.03 0.03</size></box></geometry>
        <material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material>
      </visual>
    </link>

    <!-- =============================================================
         WHEELS — 4× cylinder (r=0.075, w=0.04, m=0.5).
         Roll 90° around X so cylinder symmetry axis is along world Y;
         joints rotate about world Y (expressed in model frame).
         Track width = 0.40 m. Wheelbase = 0.30 m.
         ============================================================= -->
    <link name="front_left_wheel">
      <pose>0.15 0.20 -0.025 1.5707963 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.00077</ixx><iyy>0.00077</iyy><izz>0.00141</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry><cylinder><radius>0.075</radius><length>0.04</length></cylinder></geometry>
        <material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material>
      </visual>
      <collision name="collision">
        <geometry><cylinder><radius>0.075</radius><length>0.04</length></cylinder></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
      </collision>
    </link>
    <link name="front_right_wheel">
      <pose>0.15 -0.20 -0.025 1.5707963 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia><ixx>0.00077</ixx><iyy>0.00077</iyy><izz>0.00141</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="visual"><geometry><cylinder><radius>0.075</radius><length>0.04</length></cylinder></geometry>
        <material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material></visual>
      <collision name="collision"><geometry><cylinder><radius>0.075</radius><length>0.04</length></cylinder></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface></collision>
    </link>
    <link name="rear_left_wheel">
      <pose>-0.15 0.20 -0.025 1.5707963 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia><ixx>0.00077</ixx><iyy>0.00077</iyy><izz>0.00141</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="visual"><geometry><cylinder><radius>0.075</radius><length>0.04</length></cylinder></geometry>
        <material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material></visual>
      <collision name="collision"><geometry><cylinder><radius>0.075</radius><length>0.04</length></cylinder></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface></collision>
    </link>
    <link name="rear_right_wheel">
      <pose>-0.15 -0.20 -0.025 1.5707963 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia><ixx>0.00077</ixx><iyy>0.00077</iyy><izz>0.00141</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="visual"><geometry><cylinder><radius>0.075</radius><length>0.04</length></cylinder></geometry>
        <material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material></visual>
      <collision name="collision"><geometry><cylinder><radius>0.075</radius><length>0.04</length></cylinder></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface></collision>
    </link>

    <joint name="front_left_wheel_joint" type="revolute">
      <parent>base_link</parent><child>front_left_wheel</child>
      <axis><xyz expressed_in="__model__">0 1 0</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><friction>0.05</friction><damping>0.01</damping></dynamics>
      </axis>
    </joint>
    <joint name="front_right_wheel_joint" type="revolute">
      <parent>base_link</parent><child>front_right_wheel</child>
      <axis><xyz expressed_in="__model__">0 1 0</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><friction>0.05</friction><damping>0.01</damping></dynamics>
      </axis>
    </joint>
    <joint name="rear_left_wheel_joint" type="revolute">
      <parent>base_link</parent><child>rear_left_wheel</child>
      <axis><xyz expressed_in="__model__">0 1 0</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><friction>0.05</friction><damping>0.01</damping></dynamics>
      </axis>
    </joint>
    <joint name="rear_right_wheel_joint" type="revolute">
      <parent>base_link</parent><child>rear_right_wheel</child>
      <axis><xyz expressed_in="__model__">0 1 0</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><friction>0.05</friction><damping>0.01</damping></dynamics>
      </axis>
    </joint>

    <!-- =============================================================
         PLUGINS
         ============================================================= -->
    <!-- Skid-steer via DiffDrive: both left wheels share left_joint, both right wheels share right_joint -->
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>front_left_wheel_joint</left_joint>
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <wheel_separation>0.40</wheel_separation>
      <wheel_radius>0.075</wheel_radius>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf_diff</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <odom_publish_frequency>50</odom_publish_frequency>
      <max_linear_acceleration>3.0</max_linear_acceleration>
      <max_angular_acceleration>3.0</max_angular_acceleration>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
    </plugin>
  </model>
</sdf>
